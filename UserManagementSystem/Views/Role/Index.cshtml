@using UserManagementSystem.Application.DTO
@model RoleIndexDTO
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Role Management</h3>
        </div>
        <div class="card-body">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @* Form ID aur Hidden field add ki gayi hai *@
            <form id="roleForm" asp-controller="Role" asp-action="Create" method="post" class="mb-4">
                @Html.AntiForgeryToken()
                <input type="hidden" id="roleIdInput" asp-for="Role.Id" />

                <div class="input-group">
                    <input id="roleNameInput" asp-for="Role.RoleName" class="form-control" placeholder="Enter role name..." required />
                    <button type="submit" id="submitBtn" class="btn btn-success">Add New Role</button>
                    @* Cancel button jo sirf edit ke waqat nazar aayega *@
                    <button type="button" id="cancelBtn" class="btn btn-secondary" style="display:none;" onclick="resetForm()">Cancel</button>
                </div>
                <span asp-validation-for="Role.RoleName" class="text-danger small"></span>
            </form>

            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Role Name</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var role in Model.Roles)
                    {
                        <tr>
                            <td>@(i++)</td>
                            @* role.Name property ka use karein *@
                            <td><strong>@role.Name</strong></td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    @* Edit Button - Ab JavaScript function call karega *@
                                    <button type="button" class="btn btn-sm btn-warning me-2"
                                            onclick="prepareEdit('@role.Id', '@role.Name')">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>

                                    @* Delete Button *@
                                    <form asp-action="Delete" asp-route-id="@role.Id" method="post"
                                          onsubmit="return confirm('Kya aap waqai is role ko delete karna chahte hain?');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function prepareEdit(id, name) {
            // 1. Textbox aur Hidden field mein data bharein
            document.getElementById('roleNameInput').value = name;
            document.getElementById('roleIdInput').value = id;

            // 2. Button ka text aur style change karein
            const btn = document.getElementById('submitBtn');
            btn.innerText = "Update Role";
            btn.className = "btn btn-warning text-dark";

            // 3. Form ka Action badal kar Edit par kar dein
            document.getElementById('roleForm').action = "/Role/Edit";

            // 4. Cancel button dikhayein
            document.getElementById('cancelBtn').style.display = "inline-block";

            // Focus input field
            document.getElementById('roleNameInput').focus();
        }

        // function resetForm() {
        //     // Form ko wapis normal (Create) mode mein le aayein
        //     document.getElementById('roleNameInput').value = "";
        //     document.getElementById('roleIdInput').value = "";

        //     const btn = document.getElementById('submitBtn');
        //     btn.innerText = "Add New Role";
        //     btn.className = "btn btn-success";

        //     document.getElementById('roleForm').action = "/Role/Create";
        //     document.getElementById('cancelBtn').style.display = "none";
        // }
       function resetForm() {
    // Page ko Index action par redirect kar dein
    // Is se server-side [HttpGet] Index() call hoga
            window.location.href = '/Role/Index';
}
    </script>
}