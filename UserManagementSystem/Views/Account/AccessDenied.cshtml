@{
    ViewData["Title"] = "Access Denied";
    // Agar aap chahte hain layout nazar aaye toh null na karen
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow border-0 p-5">
                <div class="mb-4">
                    <i class="bi bi-shield-lock-fill text-danger" style="font-size: 6rem;"></i>
                </div>
                <h1 class="text-danger fw-bold">403 - Access Denied</h1>
                <p class="text-muted fs-5">
                    Restricted Area "Sorry, you don't have permission to access this resource. Please check your credentials or log in with a different account."
                </p>
                <hr />
                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 shadow-sm">
                        <i class="bi bi-house-door"></i> Back to Home
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline ms-2">
                        <button type="submit" class="btn btn-outline-secondary px-4">
                            Login with Admin
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>